# Public site URL used for sitemap and canonical links (also sets astro.config site).
PUBLIC_SITE_URL=https://example.com

# GitHub Pages project sites only — base path including slashes, e.g. /my-repo/
# ASTRO_BASE=/my-repo/

# Chromatic — enable when chromatic: true in seabuckthorn.config.ts
# Local: CHROMATIC_PROJECT_TOKEN=chpt_xxxxxxxx
# CI: add CHROMATIC_PROJECT_TOKEN as a GitHub secret

# AWS static deploy — when deploy: aws-s3 (see docs/deploy.md)
# AWS_S3_BUCKET=
# AWS_CLOUDFRONT_DISTRIBUTION_ID=
# AWS_REGION=us-east-1

# Webiny Headless CMS — when cms: webiny in seabuckthorn.config.ts (see docs/webiny.md)
# WEBINY_API_URL=https://dXXXXXXX.cloudfront.net/cms/read/EN-US
# WEBINY_API_TOKEN=
