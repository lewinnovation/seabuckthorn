# Public site URL used for sitemap and canonical links.
# Update astro.config.mjs `site` to match your production domain.
PUBLIC_SITE_URL=https://example.com

# Chromatic project token — for local `pnpm chromatic` only.
# CI uses the CHROMATIC_PROJECT_TOKEN GitHub secret.
# CHROMATIC_PROJECT_TOKEN=chpt_xxxxxxxx

# AWS static deploy (see docs/deploy.md)
# AWS_S3_BUCKET=
# AWS_CLOUDFRONT_DISTRIBUTION_ID=
# AWS_REGION=us-east-1

# Webiny Headless CMS (required when cms: "webiny" in seabuckthorn.config.ts)
# WEBINY_API_URL=https://dXXXXXXX.cloudfront.net/cms/read/EN-US
# WEBINY_API_TOKEN=
