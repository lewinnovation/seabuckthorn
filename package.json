{
  "name": "seabuckthorn",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "concurrently -n astro,sb \"astro dev\" \"storybook dev -p 6006 --no-open\"",
    "dev:astro": "astro dev",
    "dev:storybook": "storybook dev -p 6006",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro sync && tsc --noEmit -p tsconfig.json",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:storybook": "vitest run --project=storybook",
    "chromatic": "chromatic --exit-zero-on-changes",
    "chromatic:ci": "chromatic",
    "deploy:aws": "bash deploy/aws/sync.sh",
    "deploy:cloudflare": "pnpm build && pnpm exec wrangler deploy --config deploy/cloudflare/wrangler.jsonc",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.1",
    "@astrojs/react": "^5.0.6",
    "@astrojs/sitemap": "^3.7.3",
    "@headlessui/react": "^2.2.10",
    "@headlessui/tailwindcss": "^0.2.2",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.2",
    "marked": "^18.0.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook-astro/framework": "^1.2.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/builder-vite": "^10.4.1",
    "@storybook/react": "^10.4.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.7",
    "chromatic": "^17.1.0",
    "concurrently": "^10.0.0",
    "playwright": "^1.60.0",
    "storybook": "^10.4.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
