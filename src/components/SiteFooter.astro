---
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<footer class="border-t border-border-default bg-surface-secondary">
  <div class="mx-auto max-w-5xl px-4 py-8 text-sm text-text-muted">
    <p>{t("footer.tagline")}</p>
  </div>
</footer>
