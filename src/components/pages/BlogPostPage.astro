---
import Article from "../../layouts/Article.astro";
import Callout from "../content/Callout.astro";
import type { BlogPost } from "../../lib/content/types";
import { renderMarkdownToHtml } from "../../lib/markdown";
import { useTranslations } from "../../i18n/utils";
import { getStaticRoutePath } from "../../lib/i18n/resolve-path";
import type { Locale } from "../../i18n/ui";
import { render } from "astro:content";

interface Props {
  lang: Locale;
  post: BlogPost;
}

const { lang, post } = Astro.props;
const t = useTranslations(lang);

let bodyHtml: string | undefined;
let MdxContent: Awaited<ReturnType<typeof render>>["Content"] | undefined;

if (post.bodyFormat === "mdx" && post.mdxEntry) {
  const rendered = await render(post.mdxEntry);
  MdxContent = rendered.Content;
} else {
  bodyHtml = renderMarkdownToHtml(post.body);
}
---

<Article
  title={post.title}
  description={post.description}
  pubDate={post.pubDate}
>
  {
    MdxContent ? (
      <MdxContent components={{ Callout }} />
    ) : (
      <div class="prose prose-neutral max-w-none text-text-primary" set:html={bodyHtml} />
    )
  }
  <p class="mt-8">
    <a href={getStaticRoutePath("blog", lang)} class="text-accent no-underline">
      ← {t("blog.back")}
    </a>
  </p>
</Article>
