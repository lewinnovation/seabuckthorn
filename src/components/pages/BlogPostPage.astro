---
import Article from "../../layouts/Article.astro";
import Callout from "../content/Callout.astro";
import { localizedPath, useTranslations } from "../../i18n/utils";
import type { Locale } from "../../i18n/ui";
import { getCollection, render } from "astro:content";

interface Props {
  lang: Locale;
  slug: string;
}

const { lang, slug } = Astro.props;
const t = useTranslations(lang);

const posts = await getCollection(
  "blog",
  ({ data, id }) =>
    !data.draft &&
    data.locale === lang &&
    id.replace(/\.(md|mdx)$/, "").endsWith(`/${slug}`),
);

const post = posts[0];
if (!post) {
  return Astro.redirect(localizedPath(lang, "/blog/"));
}

const { Content } = await render(post);
---

<Article
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
>
  <Content components={{ Callout }} />
  <p class="mt-8">
    <a href={localizedPath(lang, "/blog/")} class="text-accent no-underline">
      ← {t("blog.back")}
    </a>
  </p>
</Article>
