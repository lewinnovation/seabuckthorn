---
import Base from "../../layouts/Base.astro";
import { render } from "astro:content";
import type { SitePage } from "../../lib/content/pages-mdx";
import type { Locale } from "../../i18n/ui";

interface Props {
  lang: Locale;
  page: SitePage;
}

const { lang, page } = Astro.props;
const { Content } = await render(page.mdxEntry);
---

<Base title={page.title} description={page.description} lang={lang}>
  <article class="prose prose-neutral max-w-none text-text-primary">
    <h1>{page.title}</h1>
    <Content />
  </article>
</Base>
