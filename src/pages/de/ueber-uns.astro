---
import SitePage from "../../components/pages/SitePage.astro";
import { listPages } from "../../lib/content/pages-mdx";

const pages = await listPages("de");
const page = pages.find((p) => p.slug === "ueber-uns");
if (!page) throw new Error("Missing German about page");
---

<SitePage lang="de" page={page} />
